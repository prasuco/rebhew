---
import Welcome from "../components/Welcome.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <div
    class="mt-40 max-w-xl mx-auto flex flex-col justify-center md:flex-row-reverse"
  >

    <div class="w-full flex items-center justify-center">
      <div class="w-full p-8 space-y-2">
        <h2 class="text-3xl font-bold text-gray-800">
          Login With Your Organization
        </h2>
        <p class="text-sm text-gray-600">
          Signin with your email and password.
        </p>
        <form method="post" action="/api/login" class="space-y-4">
          <div>
            <label class="block text-gray-600 mb-1"
              >Email <span class="required">*</span></label
            >
            <input
              name="email"
              type="email"
              placeholder="Enter your email"
              class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
            />
          </div>

          <div>
            <label class="block text-gray-600 mb-1"
              >Password

              <span class="required">*</span>
            </label>
            <input
              name="password"
              type="password"
              placeholder="Enter your password"
              class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500"
            />
          </div>

          <button type="submit" class="w-full d-btn d-btn-secondary">
            Login
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>

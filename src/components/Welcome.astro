---
import { SubscribeModal } from "./SubscribeModal";
---

<div class="flex h-screen flex-col items-center justify-center gap-3">
  <div class="image w-20 h-20 bg-emerald-400 rounded-full"></div>

  <div class="d-tooltip">
    <div class="d-tooltip-content">
      <div class="flex flex-row items-center">
        <p>a project by</p>
        <img
          src="https://github.com/prasuco.png"
          class="w-22 h-8 object-cover"
        />
      </div>
    </div>

    <h1 class="inder-sans text-3xl">rebhew.app</h1>
  </div>

  <p class="text-base">Collecting Reviews Made Easy.</p>

  <a
    href="#subscribe-modal"
    rel="modal:open"
    class="bg-[#00FF3C] px-10 py-2 text-lg w-max"
  >
    Join our Waitlist
  </a>
</div>

<div id="subscribe-modal" class="modal">
  <SubscribeModal />
</div>

